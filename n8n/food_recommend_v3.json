      "parameters": {
        "jsCode": "const raw = $input.first().json.output || '';\nlet parsed;\n\ntry {\n  parsed = JSON.parse(raw);\n} catch(e) {\n  const match = raw.match(/```(?:json)?\\n?([\\s\\S]*?)\\n?```/);\n  try { \n    parsed = match ? JSON.parse(match[1]) : { message: '추천 결과예요!', recommendations: [] }; \n  } catch(e2) { \n    parsed = { message: '추천 결과예요!', recommendations: [] }; \n  }\n}\n\nconst d = $('의도 분류').first().json;\n\nreturn [{ json: {\n  path: 'C',\n  description: d.description,\n  message: parsed.message || '취향에 맞는 식당을 골라봤어요!',\n  restaurants: parsed.recommendations || [],\n  keyword: d.keyword,\n  user_id: d.user_id\n} }];"
