        "jsCode": "const keyword     = $('키워드 추출').first().json.keyword;\nconst message     = $('키워드 추출').first().json.message;\nconst userId      = $('키워드 추출').first().json.user_id;\nconst location    = $('키워드 추출').first().json.location;\nconst foodPrefs   = $('취향 정리').first().json.food_preferences || '';\nconst allergies   = $('취향 정리').first().json.allergies || '';\n\nconst rMatches = $('식당명 검색').all().filter(r => r.json && r.json.id);\nconst mMatches = $('메뉴명 검색').all().filter(m => m.json && m.json.restaurant_id);\n\nlet path, description;\nif (rMatches.length > 0) {\n  path = 'A';\n  description = `\"${rMatches[0].json.name}\" 식당을 바로 찾았어요!`;\n} else if (mMatches.length > 0) {\n  const uniqueIds = [...new Set(mMatches.map(m => m.json.restaurant_id))];\n  path = 'B';\n  description = `\"${keyword}\" 메뉴를 판매하는 식당 ${uniqueIds.length}곳을 찾았어요!`;\n} else {\n  path = 'C';\n  description = '취향에 맞는 식당을 추천해드릴게요!';\n}\n\nconst uniqueRestaurantIds = [...new Set(mMatches.map(m => m.json.restaurant_id))];\n\nreturn [{ json: {\n  path,\n  description,\n  keyword,\n  message,\n  user_id: userId,\n  location,\n  food_preferences: foodPrefs,\n  allergies,\n  restaurant_matches: rMatches.map(r => r.json),\n  menu_restaurant_ids: uniqueRestaurantIds,\n  ids_str: uniqueRestaurantIds.join(',')\n} }];"
